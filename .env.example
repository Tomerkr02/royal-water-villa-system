NEXT_PUBLIC_DEVICE_PROVIDER=mock

TUYA_ACCESS_ID=your-tuya-access-id
TUYA_ACCESS_SECRET=your-tuya-access-secret
TUYA_API_BASE_URL=https://openapi.tuyaeu.com

# Discovery options:
# project    -> query devices from the Tuya cloud project endpoint
# device_ids -> fetch only explicit device ids from TUYA_DISCOVERY_DEVICE_IDS
TUYA_DISCOVERY_STRATEGY=project
TUYA_DISCOVERY_DEVICE_IDS=
TUYA_DISCOVERY_PAGE_SIZE=75
